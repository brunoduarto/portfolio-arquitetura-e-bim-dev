---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** Pass true to use title as-is (no "| Bruno Arq" suffix) */
  fullTitle?: boolean;
}

const {
  title,
  description = 'Arquiteto especializado em automação BIM, design computacional e desenvolvimento de ferramentas para a indústria AEC.',
  ogImage = '/og-image.png',
  ogType = 'website',
  fullTitle = false,
} = Astro.props;

const siteUrl   = Astro.site ?? new URL('https://bruno.arq.br');
const pageUrl   = new URL(Astro.url.pathname, siteUrl).toString();
const pageTitle = fullTitle ? title : `${title} | Bruno Arq`;
const absOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Bruno Duarte de Oliveira',
  jobTitle: 'Arquiteto & Desenvolvedor BIM',
  url: siteUrl.toString(),
  sameAs: [
    'https://github.com/brunoduarto',
    'https://www.linkedin.com/in/bruno-duarte-deoliveira/',
  ],
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Bruno" />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:url"         content={pageUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={absOgImage} />
    <meta property="og:locale"      content="pt_BR" />
    <meta property="og:site_name"   content="Bruno Arq" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={absOgImage} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Person schema (identifies portfolio owner to search engines) -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Slot for extra head tags from child layouts (e.g. Article schema on project pages) -->
    <slot name="head" />
  </head>
  <body class="bg-warm-50 text-ink-800 font-body antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
