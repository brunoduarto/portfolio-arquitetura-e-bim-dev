---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, category, pubDate, images, coverImage } = project.data;

const categoryLabels: Record<string, string> = {
  'scripting':           'Automação BIM',
  '3d-modeling':         '3D Modeling',
  'executive-projects':  'Proj. Executivo',
  '3d-renders':          '3D Render',
  'general-projects':    'Geral',
};
const categoryLabel = categoryLabels[category] ?? category.replace(/-/g, ' ');
const imgs = images ?? [];
const ogImage = coverImage ?? imgs[0]?.src;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Person', name: 'Bruno', url: 'https://bruno.arq.br' },
  ...(ogImage ? { image: new URL(ogImage, 'https://bruno.arq.br').toString() } : {}),
};
---

<BaseLayout title={title} description={description} ogType="article" ogImage={ogImage}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article class="max-w-6xl mx-auto px-4 py-12">

    <a
      href="/projects"
      class="inline-flex items-center gap-1 text-sm text-ink-400 hover:text-ink-600 transition-colors mb-10"
    >
      &larr; Voltar aos projetos
    </a>

    {/* Header */}
    <header class="mb-10 max-w-2xl">
      <div class="flex items-center gap-3 mb-3">
        <a
          href={`/projects?filter=${category}`}
          class="text-xs font-mono uppercase tracking-wider text-warm-600 bg-warm-100 px-2 py-1 rounded hover:bg-warm-200 transition-colors"
        >
          {categoryLabel}
        </a>
        <time class="text-xs text-ink-400 font-mono" datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long' })}
        </time>
      </div>
      <h1 class="font-display text-3xl text-ink-950 mb-3 leading-snug">{title}</h1>
      <p class="text-ink-500 text-sm leading-relaxed">{description}</p>
    </header>

    {/* Image grid */}
    {imgs.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {imgs.map((img, i) => (
          <button
            class="gallery-thumb group block rounded-lg overflow-hidden bg-warm-100 aspect-[4/3] cursor-zoom-in"
            data-index={String(i)}
            aria-label={img.caption ?? `Imagem ${i + 1}`}
          >
            <img
              src={img.src}
              alt={img.caption ?? ''}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </button>
        ))}
      </div>
    ) : (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {Array.from({ length: 6 }).map((_, i) => (
          <div class="rounded-lg bg-warm-100 aspect-[4/3] flex items-center justify-center">
            <span class="font-mono text-xs text-warm-400 uppercase tracking-wider">{categoryLabel}</span>
          </div>
        ))}
      </div>
    )}

    {/* Extra markdown content (optional) */}
    <div class="mt-12 prose prose-sm max-w-2xl text-ink-600">
      <slot />
    </div>

  </article>

  {/* Lightbox */}
  <dialog id="lightbox" class="lightbox-dialog">
    <div class="lightbox-inner">

      <button id="lb-close" class="lightbox-close" aria-label="Fechar">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="lightbox-content">
        <div class="lightbox-img-wrap">
          <img id="lb-img" src="" alt="" class="lightbox-img" />
        </div>
        <div class="lightbox-sidebar">
          <p id="lb-caption" class="lightbox-caption"></p>
          <div class="lightbox-nav">
            <button id="lb-prev" aria-label="Anterior">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <span id="lb-counter" class="lightbox-counter"></span>
            <button id="lb-next" aria-label="Próxima">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>
        </div>
      </div>

    </div>
  </dialog>
</BaseLayout>

<style>
  .lightbox-dialog {
    padding: 0;
    border: none;
    border-radius: 0.75rem;
    background: transparent;
    max-width: min(92vw, 1080px);
    width: 100%;
  }

  .lightbox-dialog::backdrop {
    background: rgba(8, 8, 8, 0.90);
    backdrop-filter: blur(6px);
  }

  .lightbox-inner {
    position: relative;
    background: #1c1815;
    border-radius: 0.75rem;
    padding: 2rem 1.5rem 1.5rem;
  }

  .lightbox-close {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #756a5b;
    border-radius: 9999px;
    transition: color 0.15s;
    z-index: 10;
  }
  .lightbox-close:hover { color: #fdf8f3; }

  .lightbox-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .lightbox-content { flex-direction: row; align-items: flex-start; gap: 2rem; }
  }

  .lightbox-img-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img {
    max-height: 75vh;
    max-width: 100%;
    width: auto;
    object-fit: contain;
    border-radius: 0.375rem;
  }

  .lightbox-sidebar {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1.25rem;
    width: 100%;
  }
  @media (min-width: 768px) {
    .lightbox-sidebar { width: 200px; flex-shrink: 0; }
  }

  .lightbox-caption {
    font-size: 0.875rem;
    line-height: 1.65;
    color: #9d9381;
    min-height: 2rem;
  }

  .lightbox-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lightbox-nav button {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #756a5b;
    border: 1px solid #514a41;
    border-radius: 9999px;
    transition: all 0.15s;
  }
  .lightbox-nav button:hover { color: #fdf8f3; border-color: #8a7f6d; }

  .lightbox-counter {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #5f564b;
    flex: 1;
    text-align: center;
  }
</style>

<script define:vars={{ imgs }}>
  const dialog  = document.getElementById('lightbox');
  const lbImg   = document.getElementById('lb-img');
  const lbCap   = document.getElementById('lb-caption');
  const lbCount = document.getElementById('lb-counter');
  let current   = 0;

  function show(i) {
    current = ((i % imgs.length) + imgs.length) % imgs.length;
    const img = imgs[current];
    lbImg.src       = img.src;
    lbImg.alt       = img.caption ?? '';
    lbCap.textContent   = img.caption ?? '';
    lbCount.textContent = `${current + 1} / ${imgs.length}`;
  }

  document.querySelectorAll('.gallery-thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      show(Number(btn.dataset.index));
      dialog.showModal();
    });
  });

  document.getElementById('lb-prev').addEventListener('click', () => show(current - 1));
  document.getElementById('lb-next').addEventListener('click', () => show(current + 1));
  document.getElementById('lb-close').addEventListener('click', () => dialog.close());

  // Close on backdrop click
  dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!dialog.open) return;
    if (e.key === 'ArrowLeft')  show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>
