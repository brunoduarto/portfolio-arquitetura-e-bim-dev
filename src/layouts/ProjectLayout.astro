---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, category, technologies, pubDate, repoUrl, coverImage } = project.data;

const categoryLabels: Record<string, string> = {
  'scripting':           'Automação BIM',
  '3d-modeling':         '3D Modeling',
  'executive-projects':  'Proj. Executivo',
  '3d-renders':          '3D Render',
  'general-projects':    'Geral',
};
const categoryLabel = categoryLabels[category] ?? category.replace(/-/g, ' ');

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: title,
  description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Person', name: 'Bruno', url: 'https://bruno.arq.br' },
  ...(repoUrl ? { codeRepository: repoUrl } : {}),
};
---

<BaseLayout title={title} description={description} ogType="article" ogImage={coverImage}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="mb-12 border-b border-warm-200 pb-8">
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-sm text-ink-400 hover:text-ink-600 transition-colors mb-6"
      >
        &larr; Voltar aos projetos
      </a>
      <p class="text-warm-600 font-mono text-sm uppercase tracking-wider mb-2">
        {categoryLabel}
      </p>
      <h1 class="font-display text-4xl md:text-5xl text-ink-950 mb-4">
        {title}
      </h1>
      <p class="text-ink-500 text-lg leading-relaxed">{description}</p>
      {technologies && technologies.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {technologies.map((tech) => <TagBadge label={tech} />)}
        </div>
      )}
      <div class="flex items-center gap-4 mt-6 text-sm text-ink-400">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long' })}
        </time>
        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-code-600 hover:text-code-700 underline"
          >
            Repositório
          </a>
        )}
      </div>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
