---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const links = [
  {
    label: 'Email',
    value: 'contato@bruno.arq.br',
    href: 'mailto:contato@bruno.arq.br',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
  {
    label: 'GitHub',
    value: 'github.com/brunoarq',
    href: 'https://github.com/brunoarq',
    icon: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z',
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/brunoarq',
    href: 'https://linkedin.com/in/brunoarq',
    icon: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z',
  },
];
---

<BaseLayout title="Contato" description="Entre em contato para projetos de automação BIM e design computacional.">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="max-w-2xl">
      <SectionHeading
        title="Contato"
        subtitle="Vamos conversar sobre automação BIM"
      />
      <p class="text-lg text-ink-600 leading-relaxed mb-12">
        Interessado em automação BIM, ferramentas IFC, ou design computacional?
        Entre em contato — estou disponível para projetos, consultoria e colaborações.
      </p>

      <div class="space-y-4">
        {links.map(({ label, value, href, icon }) => (
          <a
            href={href}
            target={href.startsWith('http') ? '_blank' : undefined}
            rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="flex items-center gap-4 bg-white rounded-lg border border-warm-200 p-5 hover:border-warm-400 hover:shadow-md transition-all group"
          >
            <div class="w-10 h-10 rounded-full bg-warm-100 flex items-center justify-center shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-warm-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <div>
              <span class="text-xs font-mono uppercase tracking-wider text-ink-400">{label}</span>
              <p class="text-ink-800 group-hover:text-warm-700 transition-colors">{value}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
