---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);

const sorted = allProjects.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tags = [
  { value: 'all',                label: 'Todos' },
  { value: 'scripting',          label: 'Automação BIM' },
  { value: '3d-modeling',        label: '3D Modeling' },
  { value: 'executive-projects', label: 'Projetos Executivos' },
  { value: '3d-renders',         label: '3D Renders' },
  { value: 'general-projects',   label: 'Projetos Gerais' },
];
---

<BaseLayout title="Projetos" description="Projetos de arquitetura, automação BIM e design computacional.">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <SectionHeading
      title="Projetos"
      subtitle="Arquitetura, automação BIM e design computacional"
    />

    {/* Tag filter */}
    <div class="flex flex-wrap gap-2 mb-12" id="tag-filters">
      {tags.map(({ value, label }) => (
        <button
          data-filter={value}
          class:list={[
            'tag-btn text-sm px-4 py-1.5 rounded-full border transition-colors cursor-pointer',
            value === 'all'
              ? 'active bg-ink-950 text-warm-50 border-ink-950'
              : 'bg-white text-ink-600 border-warm-200 hover:border-warm-400',
          ]}
        >
          {label}
        </button>
      ))}
    </div>

    {/* Project grid */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="project-grid">
      {sorted.map((project) => (
        <div data-category={project.data.category} class="project-item">
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            technologies={project.data.technologies}
            language={project.data.language}
            coverImage={project.data.coverImage ?? project.data.images?.[0]?.src}
            slug={project.id}
          />
        </div>
      ))}
    </div>

    {/* Empty state */}
    <p id="empty-state" class="hidden text-center text-ink-400 font-mono text-sm py-16">
      Nenhum projeto nesta categoria ainda.
    </p>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items   = document.querySelectorAll<HTMLElement>('.project-item');
  const empty   = document.getElementById('empty-state')!;

  function applyFilter(filter: string) {
    let visible = 0;

    items.forEach((item) => {
      const match = filter === 'all' || item.dataset.category === filter;
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    empty.classList.toggle('hidden', visible > 0);

    buttons.forEach((btn) => {
      const active = btn.dataset.filter === filter;
      btn.classList.toggle('active', active);
      btn.classList.toggle('bg-ink-950', active);
      btn.classList.toggle('text-warm-50', active);
      btn.classList.toggle('border-ink-950', active);
      btn.classList.toggle('bg-white', !active);
      btn.classList.toggle('text-ink-600', !active);
      btn.classList.toggle('border-warm-200', !active);
    });
  }

  // Apply filter from URL param on load
  const initial = new URLSearchParams(location.search).get('filter') ?? 'all';
  applyFilter(initial);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      applyFilter(filter);
      const url = new URL(location.href);
      if (filter === 'all') url.searchParams.delete('filter');
      else url.searchParams.set('filter', filter);
      history.replaceState({}, '', url.toString());
    });
  });
</script>
